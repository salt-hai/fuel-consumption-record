# ===== 应用配置示例 =====
# 复制此文件为 .env 并根据需要修改配置

# ===== 数据库配置 =====
# SQLite 数据库路径（支持相对路径或绝对路径）
DATABASE_URL=sqlite+aiosqlite:///./data/fuel.db

# ===== JWT 认证配置 =====
# JWT 密钥（生产环境务必修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# ===== API 文档配置 =====
# 是否显示 API 文档（Swagger UI / ReDoc）
DOCS_ENABLED=true
# 是否显示 OpenAPI Schema (JSON)
OPENAPI_ENABLED=true
# Swagger UI 路径
DOCS_URL=/docs
# ReDoc 路径
REDOC_URL=/redoc
# OpenAPI JSON 路径
OPENAPI_URL=/openapi.json

# ===== 应用功能开关 =====
# 是否启用用户注册（生产环境可设为 false）
REGISTRATION_ENABLED=true
# 邮箱白名单（逗号分隔，空表示不限制）
# 完整邮箱: user@example.com
# 域名通配: @example.com（允许该域名所有邮箱）
# 示例: user1@example.com,@company.com,@gmail.com
EMAIL_WHITELIST=
# 是否启用数据导出功能
EXPORT_ENABLED=true
# 是否启用保养提醒功能
MAINTENANCE_ENABLED=true

# ===== 安全配置 =====
# CORS 配置说明：
# - 生产环境使用 Nginx 反向代理，前后端同源，不需要 CORS，设为 false
# - 开发环境前端后端分离（5173/8000），需要 CORS，设为 true
CORS_ENABLED=true
# 允许的跨域源（仅开发环境使用）
CORS_ORIGINS=http://localhost:5173

# ===== 调试配置 =====
# 调试模式（生产环境设为 false）
DEBUG=false
# 是否显示详细错误信息
SHOW_DETAILED_ERRORS=false

# ===== 维护模式 =====
# 是否开启维护模式（开启后 API 返回维护信息）
MAINTENANCE_MODE=false
# 维护提示信息
MAINTENANCE_MESSAGE=系统维护中，请稍后访问

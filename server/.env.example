# ===== 应用配置示例 =====
# 复制此文件为 .env 并根据需要修改配置

# ===== 数据库配置 =====
# SQLite 数据库路径（支持相对路径或绝对路径）
DATABASE_URL=sqlite+aiosqlite:///./data/fuel.db

# ===== JWT 认证配置 =====
# JWT 密钥（生产环境务必修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# ===== API 文档配置 =====
# 是否显示 API 文档（Swagger UI / ReDoc）
DOCS_ENABLED=true
# 是否显示 OpenAPI Schema (JSON)
OPENAPI_ENABLED=true
# Swagger UI 路径
DOCS_URL=/docs
# ReDoc 路径
REDOC_URL=/redoc
# OpenAPI JSON 路径
OPENAPI_URL=/openapi.json

# ===== 应用功能开关 =====
# 是否启用用户注册（生产环境可设为 false）
REGISTRATION_ENABLED=true
# 是否启用数据导出功能
EXPORT_ENABLED=true
# 是否启用保养提醒功能
MAINTENANCE_ENABLED=true

# ===== 安全配置 =====
# 是否启用 CORS
CORS_ENABLED=true
# 允许的 CORS 源（逗号分隔，* 表示允许所有）
# 生产环境建议设置为: http://localhost:5173,https://yourdomain.com
CORS_ORIGINS=*

# ===== 调试配置 =====
# 调试模式（生产环境设为 false）
DEBUG=false
# 是否显示详细错误信息
SHOW_DETAILED_ERRORS=false

# ===== 维护模式 =====
# 是否开启维护模式（开启后 API 返回维护信息）
MAINTENANCE_MODE=false
# 维护提示信息
MAINTENANCE_MESSAGE=系统维护中，请稍后访问

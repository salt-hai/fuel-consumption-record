# ============================================
# 汽车油耗记录系统 - 生产环境配置示例
# ============================================
# 此文件包含推荐的生产环境安全配置
# 使用方法：cp .env.production.example .env
# ============================================

# ===== 数据库配置 =====
DATABASE_URL=sqlite+aiosqlite:////data/fuel.db

# ===== JWT 认证配置 =====
# ⚠️ 必须修改！生成命令: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_RANDOM_STRING_FROM_OPENSSL_RAND_HEX_32

# ===== API 文档配置 =====
# 生产环境关闭文档暴露
DOCS_ENABLED=false
OPENAPI_ENABLED=false

# ===== 应用功能开关 =====
# 生产环境关闭公开注册，由管理员添加用户
REGISTRATION_ENABLED=false
EXPORT_ENABLED=true
MAINTENANCE_ENABLED=true

# ===== 安全配置 =====
# 生产环境使用 Nginx 反向代理，前后端同源，不需要 CORS
CORS_ENABLED=false

# ===== 调试配置 =====
DEBUG=false
SHOW_DETAILED_ERRORS=false

# ===== 维护模式 =====
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=系统维护中，请稍后访问

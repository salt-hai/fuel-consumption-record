# ============================================
# 汽车油耗记录系统 - 环境变量配置示例
# ============================================
# 使用方法：
#   1. 复制此文件: cp .env.example .env
#   2. 修改 SECRET_KEY 为随机字符串（必须！）
#   3. 根据需要调整其他配置
# ============================================

# ===== 数据库配置 =====
# 生产环境使用绝对路径（LinuxServer.io 规范：/data）
DATABASE_URL=sqlite+aiosqlite:////data/fuel.db

# ===== JWT 认证配置 =====
# ⚠️ 生产环境必须修改为随机字符串！
# 生成命令: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-string-use-openssl-rand-hex-32

# ===== API 文档配置 =====
# 生产环境建议关闭文档暴露
DOCS_ENABLED=false
OPENAPI_ENABLED=false
# 自定义文档路径（默认 /docs, /redoc）
# DOCS_URL=/docs
# REDOC_URL=/redoc

# ===== 应用功能开关 =====
# 生产环境建议关闭公开注册
REGISTRATION_ENABLED=false
# 邮箱白名单（逗号分隔，空表示不限制）
# 完整邮箱: user@example.com
# 域名通配: @example.com（允许该域名所有邮箱）
# 示例: user1@example.com,@company.com,@gmail.com
EMAIL_WHITELIST=
# 数据导出功能
EXPORT_ENABLED=true
# 保养提醒功能
MAINTENANCE_ENABLED=true

# ===== 安全配置 =====
# CORS 配置（仅开发环境需要，生产环境 Nginx 反代不需要）
# 开发环境: 前端 localhost:5173, 后端 localhost:8000
# 生产环境: Nginx 反代，前后端同源，设为 false
CORS_ENABLED=true
# 允许的跨域源（仅开发环境使用）
CORS_ORIGINS=http://localhost:5173

# ===== 调试配置 =====
# 生产环境必须设为 false
DEBUG=false
# 生产环境必须设为 false（不暴露详细错误）
SHOW_DETAILED_ERRORS=false

# ===== 维护模式 =====
# 开启后只返回维护信息（健康检查端点仍可用）
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=系统维护中，请稍后访问

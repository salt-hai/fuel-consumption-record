# ===== 数据库配置 =====
# 生产环境使用绝对路径（LinuxServer.io 规范：/data）
DATABASE_URL=sqlite+aiosqlite:////data/fuel.db

# ===== JWT 认证配置 =====
# 生产环境必须修改为随机字符串
SECRET_KEY=your-secret-key-change-in-production

# ===== API 文档配置 =====
# 是否启用 Swagger UI / ReDoc
DOCS_ENABLED=true
OPENAPI_ENABLED=true

# ===== 应用功能开关 =====
# 是否允许用户注册（生产环境可关闭）
REGISTRATION_ENABLED=true
# 是否启用数据导出功能
EXPORT_ENABLED=true
# 是否启用保养提醒功能
MAINTENANCE_ENABLED=true

# ===== 安全配置 =====
# 是否启用 CORS
CORS_ENABLED=true
# 允许的跨域源（逗号分隔，* 表示允许所有）
CORS_ORIGINS=*

# ===== 调试配置 =====
# 调试模式（生产环境设为 false）
DEBUG=false
# 是否显示详细错误信息
SHOW_DETAILED_ERRORS=false

# ===== 维护模式 =====
# 是否开启维护模式
MAINTENANCE_MODE=false
# 维护提示信息
MAINTENANCE_MESSAGE=系统维护中，请稍后访问
